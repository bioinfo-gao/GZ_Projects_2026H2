// nf-core/sarek Study B 过渡期配置 —— 与仍在收尾的 Study A(p14_sarek_A)错峰并存时用
// 用途:Study A 处于 Mutect2 收尾尾段(实测仅~12线程/~12GB),此配置让 Study B 现在就启动、
//   用掉当前闲置产能(主要跑 B 的比对),同时给 A 留足余量,合计不超 28核/56线程预算、内存不顶穿。
// 过渡完成(Study A 结束)后,带 -resume 重启 Study B 换成 local_resources_full_machine.config(cpus=56)。
// 每进程 cpus/memory 与满机版一致(按 Study A trace 实测),仅 executor 上限压低。
executor {
    name = 'local'
    cpus = 40          // 40/16=2个BWAMEM2并发(32线程)+ A的~12线程 ≈ 44线程,在56预算内
    memory = '80 GB'   // 2×BWAMEM2(72GB) 放得下;+A的~12GB ≈ 84GB,留40GB余量(不撞A)
    queueSize = 16
}
process {
    withName: '.*BWAMEM2_MEM.*'     { cpus = 16; memory = '36 GB' }
    withName: '.*BWAMEM2_INDEX.*'   { cpus = 8;  memory = '60 GB' }
    withName: '.*MARKDUPLICATES.*'  { cpus = 2;  memory = '36 GB' }
    withName: '.*TIDDIT.*'          { cpus = 4;  memory = '58 GB' }  // 内存自动限;过渡期一般轮不到
    withName: '.*HAPLOTYPECALLER.*' { cpus = 4;  memory = '7 GB'  }
    withName: '.*GENOTYPEGVCFS.*'   { cpus = 4;  memory = '10 GB' }
    withName: '.*MUTECT2.*'         { cpus = 4;  memory = '7 GB'  }
    withName: '.*MOSDEPTH.*'        { cpus = 4;  memory = '4 GB'  }
    withName: '.*SAMTOOLS_STATS.*'  { cpus = 2;  memory = '4 GB'  }
    withLabel: 'process_low'         { cpus = 2;  memory = '6 GB'  }
    withLabel: 'process_medium'      { cpus = 4;  memory = '14 GB' }
    withLabel: 'process_high'        { cpus = 12; memory = '36 GB'; time = '72h' }
    withLabel: 'process_high_memory' { memory = '60 GB' }
}
