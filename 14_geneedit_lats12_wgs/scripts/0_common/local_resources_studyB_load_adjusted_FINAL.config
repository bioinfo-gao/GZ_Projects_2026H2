// nf-core/sarek —— 项目14 Study B(germline) 独占整机 · 负载修正终版(FINAL)
// ============================================================================
// 用途:Study B germline 独占整机跑。**取代** local_resources_full_machine.config
//   (后者 executor.cpus=56,实测在 CNN+HC 相位重叠时 load 冲到 152,详见
//    docs/resource_pressure_incident_0713.md)。今后 Study B solo 一律用本文件。
//
// 设计目标:观测 load 稳定 ≤56(CLAUDE.md 稳态 56 线程预算),绝不再现 150+ 峰值。
//
// 为何 executor.cpus = 48 而不是 56:
//   load average 计入"运行中 + 不可中断(D状态,等磁盘I/O)"线程。germline 有
//   MarkDup(读写~292G)/TIDDIT(~417G) 等 I/O 大户会制造 D 状态线程。若 cpus=56,
//   真实核需求顶满 56,再叠 iowait → load 必然过 56–60。设 48 留 8 线程硬件余量
//   吸收 iowait + OS/交互 → 真实核需求封顶 48,观测 load 稳在 ~45–56。
//   48 仍够 5 个 CNN 并发(5×9=45)、6 样本顺畅流过,不牺牲吞吐。
//
// 三处关键修正 vs full_machine.config:
//   1. executor.cpus 56 → 48(压 load 天花板,留 iowait 余量)
//   2. CNNSCOREVARIANTS 显式 cpus=9(实测≈8.7核) —— 核心修正,原来无声明被漏判
//   3. 每进程 cpus 按 execution_trace 实测右调,让核预算成为"真实"约束(而非虚高声明)
//
// 相位重叠说明:nextflow 一样本 HC 完成即启该样本 CNN,不等所有样本→HC尾巴与CNN会叠。
//   本配置下 nextflow 按"声明cpus之和≤48"调度,且声明已=实测,故真实核需求 ≤48,叠加也不破顶。
//
// 数据来源:output_A/output_B 的 execution_trace_*.txt(%cpu/peak_rss/rchar/wchar 实测)。
// 关联四联档见 docs/resource_pressure_incident_0713.md 顶部索引。
// ============================================================================
executor {
    name = 'local'
    cpus = 48          // 负载天花板:真实核需求封顶48,留 56-48=8 线程给 iowait/OS/交互 → load 目标 ≤56
    memory = '108 GB'  // 留 ~17GB 给 OS/cache(内存从不是本项目 germline 的约束,全程余 85G+)
    queueSize = 24     // 非约束值;实际并发由 cpus∧memory 双预算自动决定
}
process {
    // cpus/memory 全部按 execution_trace 实测右调,让 nextflow 核∧内存双预算成为真实约束
    withName: '.*BWAMEM2_MEM.*'      { cpus = 16; memory = '36 GB' }  // 实测~12-16核/峰值~34GB → 48/16=3并发
    withName: '.*BWAMEM2_INDEX.*'    { cpus = 8;  memory = '60 GB' }  // 一次性,内存重
    withName: '.*MARKDUPLICATES.*'   { cpus = 2;  memory = '36 GB' }  // CPU仅~1.4核,但I/O~292G(内存+I/O重)
    withName: '.*TIDDIT.*'           { cpus = 4;  memory = '58 GB' }  // 内存~57G+I/O~417G双重→内存自动限≈1并发
    withName: '.*CNNSCOREVARIANTS.*' { cpus = 9;  memory = '8 GB'  }  // ★实测≈8.7核/1.8GB → 48/9≈5并发,关键修正
    withName: '.*HAPLOTYPECALLER.*'  { cpus = 4;  memory = '7 GB'  }  // 实测~2.2-4.2核,任务多尾巴长
    withName: '.*GENOTYPEGVCFS.*'    { cpus = 4;  memory = '10 GB' }
    withName: '.*MUTECT2.*'          { cpus = 4;  memory = '7 GB'  }
    withName: '.*MOSDEPTH.*'         { cpus = 4;  memory = '4 GB'  }
    withName: '.*SAMTOOLS_STATS.*'   { cpus = 2;  memory = '4 GB'  }
    withLabel: 'process_low'          { cpus = 2;  memory = '6 GB'  }
    withLabel: 'process_medium'       { cpus = 4;  memory = '14 GB' }
    withLabel: 'process_high'         { cpus = 12; memory = '36 GB'; time = '72h' }
    withLabel: 'process_high_memory'  { memory = '60 GB' }
}
