// nf-core/sarek 本机资源上限 —— 项目14（复用 proj13 稳健配置）
// 服务器 64 逻辑核/125G；CLAUDE.md 上限 ≤28 物理核/≤56 线程。
//
// 2026-07-08 精调（Study A 运行10h后发现）：sarek 把每样本拆成12个区间子任务
// （非整基因组单次比对），实测单个 BWAMEM2_MEM 子任务只用 ~18GB RAM（配置原写
// 50GB，严重高估，导致 nextflow 按"申报内存"核算并发席位，白白浪费并发空间）。
// 因此：内存配额下调到贴近实测值（留安全余量），queueSize 从 2 提到 3——
// 3×16=48线程（=executor自身cpu上限，仍在 CLAUDE.md 56线程内，留8线程给系统/交互）；
// 3×24GB=72GB（远低于 108GB executor 内存上限，也远低于服务器 125G 总量）。
executor {
    name = 'local'; cpus = 48; memory = '108 GB'; queueSize = 3
}
process {
    withLabel: 'process_low'         { cpus = 2;  memory = '6 GB'  }
    withLabel: 'process_medium'      { cpus = 6;  memory = '16 GB' }
    withLabel: 'process_high'        { cpus = 16; memory = '40 GB'; time = '72h' }
    withLabel: 'process_high_memory' { memory = '50 GB' }
    withName: '.*BWAMEM2_MEM.*'      { cpus = 16; memory = '24 GB' }  // 实测~18GB，原50GB严重高估
    withName: '.*BWAMEM2_INDEX.*'    { cpus = 8;  memory = '60 GB' }
    withName: '.*MARKDUPLICATES.*'   { cpus = 8;  memory = '40 GB' }
    withName: '.*MUTECT2.*'          { cpus = 8;  memory = '24 GB' }
    withName: '.*TIDDIT.*'           { cpus = 8;  memory = '20 GB' }
    withName: '.*MOSDEPTH.*'         { cpus = 6;  memory = '16 GB' }
}
