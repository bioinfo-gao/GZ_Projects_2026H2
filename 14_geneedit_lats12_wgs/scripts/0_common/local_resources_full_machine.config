// nf-core/sarek 满机配置 —— 项目14 Study B(germline)独占整机时用
// 依据:CLAUDE.md "Per-part resource configs" 规则 + Study A execution_trace 实测。
// 核心:让"核预算(56线程)"与"如实声明的内存"成为约束,而非 queueSize;
//   每进程 cpus/memory 按 Study A trace 实测右调(见下注),避免虚高声明浪费并发席位。
// ⚠ 与并跑降配版(local_resources.config, queueSize=3)区分:此版仅在 Study B 独占整机时用。
executor {
    name = 'local'
    cpus = 56          // = CLAUDE.md 线程预算(留8线程给OS/交互);queueSize 不再是节流点
    memory = '108 GB'  // 留 ~17GB 给 OS/cache
    queueSize = 24     // 非约束值;实际并发由 cpus∧memory 双预算自动决定
}
process {
    // 内存全部按 Study A trace 实测峰值 + 安全余量声明,让 nextflow 内存调度自动防 OOM
    withName: '.*BWAMEM2_MEM.*'     { cpus = 16; memory = '36 GB' }  // 实测峰值~34GB
    withName: '.*BWAMEM2_INDEX.*'   { cpus = 8;  memory = '60 GB' }
    withName: '.*MARKDUPLICATES.*'  { cpus = 2;  memory = '36 GB' }  // 实测~34GB,CPU仅1.3核
    withName: '.*TIDDIT.*'          { cpus = 4;  memory = '58 GB' }  // 实测峰值57GB!(内存自动限≈1并发)
    withName: '.*HAPLOTYPECALLER.*' { cpus = 4;  memory = '7 GB'  }  // 实测~4.5GB,轻→可14并发
    withName: '.*GENOTYPEGVCFS.*'   { cpus = 4;  memory = '10 GB' }
    withName: '.*MUTECT2.*'         { cpus = 4;  memory = '7 GB'  }
    withName: '.*MOSDEPTH.*'        { cpus = 4;  memory = '4 GB'  }
    withName: '.*SAMTOOLS_STATS.*'  { cpus = 2;  memory = '4 GB'  }
    withLabel: 'process_low'         { cpus = 2;  memory = '6 GB'  }
    withLabel: 'process_medium'      { cpus = 4;  memory = '14 GB' }
    withLabel: 'process_high'        { cpus = 12; memory = '36 GB'; time = '72h' }
    withLabel: 'process_high_memory' { memory = '60 GB' }
}
