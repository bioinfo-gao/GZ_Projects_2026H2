// Nextflow resource config — server: 32 CPUs / 128 GB RAM
// Reserved for OS + SSH: 4 CPUs / 20 GB RAM
// Pipeline budget: 28 CPUs / 108 GB RAM

executor {
    name   = 'local'
    cpus   = 28
    memory = '108 GB'
}

process {
    // SortMeRNA (高耗能): 4 * 7 = 28 CPUs
    withName: 'SORTMERNA' {
        cpus     = 7
        memory   = '10 GB'
        maxForks = 4
    }

    // STAR align (内存大): 2 * 14 CPUs, 2 * 35 GB
    withName: 'STAR_ALIGN' {
        cpus     = 14
        memory   = '35 GB'
        maxForks = 2
    }

    // Salmon quant: 4 * 7 = 28 CPUs
    withName: 'SALMON_QUANT' {
        cpus     = 7
        memory   = '15 GB'
        maxForks = 4
    }

    // Picard MarkDuplicates: 7 * 4 = 28 CPUs
    withName: 'PICARD_MARKDUPLICATES' {
        cpus     = 4
        memory   = '12 GB'
        maxForks = 7
    }

    // 中等资源任务
    withLabel: 'process_medium' {
        cpus     = 4
        memory   = '8 GB'
        maxForks = 7
    }

    // 轻量级任务
    withLabel: 'process_low' {
        cpus     = 2
        memory   = '4 GB'
        maxForks = 14
    }
}
