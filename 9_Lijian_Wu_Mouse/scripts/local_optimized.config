// Nextflow resource config — server: 64 CPUs / 125 GB RAM
// Reserved for OS + SSH: budget capped at 28 CPUs / 108 GB RAM per CLAUDE.md hard limit
executor {
    name   = 'local'
    cpus   = 28
    memory = '108 GB'
}

process {
    withName: 'SORTMERNA' {
        cpus     = 7
        memory   = '10 GB'
        maxForks = 4
    }

    withName: 'STAR_ALIGN' {
        cpus     = 14
        memory   = '35 GB'
        maxForks = 2
    }

    withName: 'SALMON_QUANT' {
        cpus     = 7
        memory   = '15 GB'
        maxForks = 4
    }

    withName: 'PICARD_MARKDUPLICATES' {
        cpus     = 4
        memory   = '12 GB'
        maxForks = 7
    }

    withLabel: 'process_medium' {
        cpus     = 4
        memory   = '8 GB'
        maxForks = 7
    }

    withLabel: 'process_low' {
        cpus     = 2
        memory   = '4 GB'
        maxForks = 14
    }
}
