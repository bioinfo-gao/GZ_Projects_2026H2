// Nextflow resource config — server: 64 CPUs / 125 GB RAM
// Reserved for OS + SSH: budget capped at 28 CPUs / 108 GB RAM per CLAUDE.md hard limit
executor {
    name   = 'local'
    cpus   = 28
    memory = '108 GB'
}

process {
    withName: 'SORTMERNA' {
        cpus     = 7
        memory   = '10 GB'
        maxForks = 4
    }

    withName: 'STAR_ALIGN' {
        cpus     = 14
        memory   = '35 GB'
        maxForks = 2
    }

    withName: 'SALMON_QUANT' {
        cpus     = 7
        memory   = '15 GB'
        maxForks = 4
    }

    withName: 'PICARD_MARKDUPLICATES' {
        cpus     = 4
        memory   = '12 GB'
        maxForks = 7
    }

    // ⚠️ RETROACTIVE ADDITION — added 2026-07-22, ~18 days AFTER this project's actual run
    // (config originally written/used 2026-07-04, project delivered 2026-07-06).
    // This block was NOT part of the config project 9 actually ran with — project 9's real
    // execution had NO override for TRIMGALORE at all (it silently inherited nf-core's
    // 'process_high' default, 12 cpus/task, from base.config). Do NOT assume project 9's
    // historical execution_trace/timing logs reflect this block — they don't; they were
    // produced under the ORIGINAL (unpatched) config below this comment's date.
    // Backported here purely so this file is safe to reuse as a COPY-FROM template for
    // future nf-core/rnaseq projects, after the bug was found + fixed in project 19
    // (2026-07-22, see facilities/software_pitfalls/nextflow.md and
    // facilities/Server/nextflow_pipeline/自定义resource_config漏配label与过度修复_教训_0722.md).
    withName: 'TRIMGALORE' {
        cpus     = 7
        memory   = '16 GB'
        maxForks = 2
    }

    withLabel: 'process_medium' {
        cpus     = 4
        memory   = '8 GB'
        maxForks = 7
    }

    withLabel: 'process_low' {
        cpus     = 2
        memory   = '4 GB'
        maxForks = 14
    }
}
