// 限制 local 执行器的资源上限，防止它把服务器压垮
// 总资源：28 CPUs + 90 GB 内存（预留 4 CPUs 给系统）
executor {
    name = 'local'
    cpus   = 28
    memory = '90 GB'
}

process {
    // 强制限制 SortMeRNA 这种高耗能任务的并行数
    withName: 'SORTMERNA' {
        cpus = 7           // 每个样本分 7 核
        memory = '10 GB'   // 显式指定内存
        maxForks = 4       // 最多同时跑 4 个样本 (4*7=28)
    }
    
    // 强制限制 STAR 的并行数 (因为内存占用大)
    withName: 'STAR_ALIGN' {
        cpus = 14
        memory = '35 GB'   // 人类基因组 STAR 比对建议 25GB
        maxForks = 2       // 每次只跑 2 个样本，防止内存溢出 (2*14=28 CPUs, 2*25=50GB)
    }
    
    // Salmon 定量也需要较多内存
    withName: 'SALMON_QUANT' {
        cpus = 7
        memory = '15 GB'
        maxForks = 4       // 4*7=28 CPUs, 4*15=60GB，与 STAR 错峰运行
    }
    
    // Picard 去重步骤
    withName: 'PICARD_MARKDUPLICATES' {
        cpus = 4
        memory = '12 GB'
        maxForks = 7       // 7*4=28 CPUs
    }
    
    // 其他中等资源需求任务
    withLabel: 'process_medium' {
        cpus = 4
        memory = '8 GB'
        maxForks = 7       // 7*4=28 CPUs
    }
    
    // 轻量级任务
    withLabel: 'process_low' {
        cpus = 2
        memory = '4 GB'
        maxForks = 14      // 14*2=28 CPUs
    }
}