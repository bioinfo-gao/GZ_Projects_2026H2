// 限制 local 执行器的资源上限，防止它把服务器压垮
// CC: 用户确认机器是 32 物理核心/64 线程(超线程)、125GB 内存(用户称128G)、磁盘7T足够不是瓶颈。
// CC: 纠正：之前误用 nproc 报出的 64 逻辑线程当CPU总额度(=60)。STAR/SortMeRNA 这类比对任务
// CC: 是计算/内存带宽密集型，超线程并不能提供接近2倍的真实吞吐，会导致物理核心被超订~2倍反而更慢。
// CC: 因此 CPU 额度按物理核心数(32)计算，预留4核给系统后取28(与原配置一致，未改动)。
// CC: 内存是真实物理资源、不受超线程影响，按实测125GB预留约15GB给系统/Nextflow守护进程，由90GB上调为110GB。
executor {
    name = 'local'
    cpus   = 28
    memory = '110 GB'
}

process {
    // 强制限制 SortMeRNA 这种高耗能任务的并行数
    withName: 'SORTMERNA' {
        cpus = 24          // CC: 内存才是真正瓶颈(见下)，maxForks强制为1，CPU可独占给这一个任务，留4核给系统/其他轻量任务
        memory = '100 GB'  // CC: 实测发现严重问题：原10GB声明完全失真。实跑样本(mouse_42)在index 5/8、运行13.5h时
                            // CC: RSS已达53GB且仍在线性增长(~12MB/s)，/proc/[pid]/smaps_rollup确认几乎全是
                            // CC: Private_Dirty/Anonymous内存(真实占用，非mmap文件缓存可回收)，并非SortMeRNA自己
                            // CC: 日志里报的"Memory KB"(只有几MB，那是索引内存，不是kvdb/读跟踪结构的真实占用)。
                            // CC: sortmerna -h 确认无对齐阶段内存上限参数(-m只控制建索引内存)。旧的10GB声明会让
                            // CC: 调度器误判4个并发(=40GB)很安全，实际1个任务就可能逼近上百GB，多个并发=OOM/swap颠簸风险。
                            // CC: 改为保守值100GB(125GB物理内存-OS预留)，配合maxForks=1强制串行，避免同时挤爆内存。
        maxForks = 1        // CC: 强制串行：根据上面实测，内存远不够支撑2个并发任务，CPU层面的并行数已不重要
        time = 48.h         // CC: nf-core/rnaseq默认16h时间限制对当前数据量+8个参考库太短，mouse_32/41/48等样本已被中途kill(exit 143)
    }

    // 强制限制 STAR 的并行数 (因为内存占用大)
    withName: 'STAR_ALIGN' {
        cpus = 9            // CC: STAR这一步是内存瓶颈不是CPU瓶颈，按内存反推CPU：110GB/30GB≈3并行，28核/3≈9核每样本，比14核更充分利用并行度
        memory = '30 GB'   // CC: 小鼠基因组(GRCm39)比人类基因组小约12%，峰值内存需求更低，由32GB下调为30GB；按用户要求多留余量避免触发swap
        maxForks = 3       // CC: 由2上调为3 (3*9=27 CPUs, 3*30=90GB)，内存仍留20GB余量；单样本会比14线程慢一些，但总吞吐应更高
    }

    // Salmon 定量也需要较多内存
    withName: 'SALMON_QUANT' {
        cpus = 7
        memory = '15 GB'
        maxForks = 4       
    }

    // Picard 去重步骤
    withName: 'PICARD_MARKDUPLICATES' {
        cpus = 4
        memory = '12 GB'
        maxForks = 7       
    }

    // 其他中等资源需求任务
    withLabel: 'process_medium' {
        cpus = 4
        memory = '8 GB'
        maxForks = 7       
    }

    // 轻量级任务
    withLabel: 'process_low' {
        cpus = 2
        memory = '4 GB'
        maxForks = 14     
    }
}
