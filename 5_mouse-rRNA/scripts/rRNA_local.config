// Local rRNA database configuration for offline use
params {
    // Point to local rRNA database directory
    ribo_database_manifest = "${projectDir}/rRNA_databases/sortmerna_database_manifest.txt"
}

// Create the manifest file that lists all database files
process {
    withName: 'SORTMERNA' {
        beforeScript = '''
            # Create manifest file listing all local rRNA database files
            cat > sortmerna_database_manifest.txt << EOF
            ${projectDir}/rRNA_databases/rfam-5.8s-database-id98.fasta
            ${projectDir}/rRNA_databases/rfam-5s-database-id98.fasta
            ${projectDir}/rRNA_databases/silva-arc-16s-id95.fasta
            ${projectDir}/rRNA_databases/silva-arc-23s-id98.fasta
            ${projectDir}/rRNA_databases/silva-bac-16s-id90.fasta
            ${projectDir}/rRNA_databases/silva-bac-23s-id98.fasta
            ${projectDir}/rRNA_databases/silva-euk-18s-id95.fasta
            ${projectDir}/rRNA_databases/silva-euk-28s-id98.fasta
            EOF
        '''
    }
}