// nf-core/mag 5.4.2 local caps — 复用 15_mag_setup 已验证配置。
// 现代 nf-core 模板：资源上限只认 process.resourceLimits（--max_cpus/--max_memory 已失效）。
// 125 GB RAM 是本机唯一硬墙 —— co-assembly 用 MEGAHIT（--skip_spades），GTDB-Tk 用 split-tree。
process {
    resourceLimits = [
        cpus: 24,
        memory: 110.GB,
        time: 96.h
    ]
}
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = '/Work_bio/gao/configs/.singularity'
    pullTimeout = '30m'
}
