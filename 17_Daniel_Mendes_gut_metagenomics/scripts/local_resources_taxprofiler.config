// nf-core/taxprofiler local caps — 复用 8_taxprofiler_setup 已验证配置。
// Server 32 物理核/64 线程, 125 GB RAM。硬上限 28 核/56 线程，留 OS/SSH 余量。
executor {
    cpus   = 24
    memory = '96.GB'
}
process {
    resourceLimits = [
        cpus: 24,
        memory: 96.GB,
        time: 24.h
    ]
}
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = '/Work_bio/gao/configs/.singularity'
}
