// Project 16 — Wenliang Pan human germline WGS (2 samples)
// Context: runs SOLO on the server (no co-running pipeline as of 2026-07-16).
// Machine: 32 physical cores / 64 threads, 125GB RAM. Sustained cap 28 cores / 56 threads.
//
// 2026-07-16 — RE-TUNED FOR THE VARIANT-CALLING PHASE (per-part resource config, proj14 lesson).
//   The original queueSize=2 was sized for the ALIGNMENT phase (2 samples x BWAMEM2 @16 cpus
//   = 32 threads) and was correct there. Once the run reached the HAPLOTYPECALLER scatter the
//   task shape inverted — dozens of small ~2-thread interval tasks instead of 2 fat ones — so
//   the same queueSize became a throttle: 2 RUNNING / 54 queued, ~4.4 of 56 threads busy
//   (load 4.2, 110GB RAM idle). Same failure mode as proj14 Study B (queueSize=3 -> 21% CPU).
//
// Sizing basis = MEASURED, with deliberate headroom (not declared defaults):
//   HAPLOTYPECALLER measured ~219% CPU (= 2.2 threads; matches --native-pair-hmm-threads 2)
//   and peak RSS ~4.7GB, but inherits sarek base.config withLabel:process_low = cpus 2 /
//   memory 12.GB. The cpus figure is already honest; the 12GB is 2.5x the real footprint, and
//   Nextflow's local executor budgets concurrency on DECLARED memory — so that overdeclaration,
//   not cpus, is what caps parallelism once queueSize is lifted. Declare 10.GB: still ~2x the
//   measured 4.7GB peak, and keeps -Xmx at 8192M (vs 9830M) — comfortably above observed use.
//
// Resulting HC concurrency = min(queueSize 24, cpus 52/2 = 26, memory 112/10 = 11) -> 11 tasks
//   ~= 24 real threads, leaving room for Sample_B's SV callers (TIDDIT peaks 24-36GB) to run
//   alongside. Real RAM at that point ~11x4.7 + TIDDIT ~30 = ~82GB of 125GB. Headroom intact.

process {
    cpus   = 16
    memory = 50.GB

    // DO NOT retune BWAMEM2/MARKDUPLICATES: both are COMPLETE for both samples and their
    // script text embeds these values (bwa-mem2 -t 16; MarkDuplicates -Xmx from task.memory).
    // Changing either rewrites the command, changes the task hash, and nukes the -resume cache
    // for ~8h of finished alignment work. Resource directives alone don't bust the cache —
    // command-affecting ones do. (proj16 spark-markdup lesson, 2026-07-16)
    withName: 'BWAMEM2_MEM' {
        cpus   = 16
        memory = 60.GB
    }

    // Regular GATK4 MarkDuplicates (single-threaded, ~3.5h/sample but reliable, emits metrics inline
    // so NO separate EstimateLibraryComplexity). NOTE: we tried --use_gatk_spark markduplicates and
    // REVERTED it (2026-07-16): Spark markdup doesn't emit metrics, so sarek added a standalone
    // GATK4_ESTIMATELIBRARYCOMPLEXITY that thrashed for 6h+ on this WGS (net regression, cores idle).
    // Generous memory reduces temp-file spill. cpus modest since the tool is single-threaded.
    withName: '.*MARKDUPLICATES.*' {
        cpus   = 6
        memory = 50.GB
    }

    // Sized from measured usage (see header). withName beats sarek's withLabel:process_low.
    // Verified on the 2026-07-16 retune: the 2 HC tasks that had finished before the restart
    // still hit the -resume cache afterwards, i.e. dropping memory 12->10.GB (-Xmx 9830->8192M)
    // did NOT bust their hash. Resource directives stay out of the task hash even when the
    // module derives -Xmx from task.memory.
    withName: '.*HAPLOTYPECALLER.*' {
        cpus   = 2
        memory = 10.GB
    }

    // Defensive: CNNScoreVariants is a hidden CPU hog (~8.7 cores/task, low RSS,
    // memory-throttling does NOT limit it). This pin is now LOad-BEARING, not just belt-and-
    // braces: queueSize=2 used to cap it implicitly, and that cap is gone as of this retune.
    // (proj14 load-152 lesson)
    withName: '.*CNNSCOREVARIANTS.*' {
        cpus = 9
    }
}

executor {
    name      = 'local'
    // queueSize is deliberately NON-binding now; cpus/memory below are the real governors,
    // so each phase self-sizes to its own task shape instead of being capped by a task count.
    queueSize = 24
    cpus      = 52       // of 64 threads; >=56-cap minus slack for OS/SSH/interactive use
    memory    = 112.GB   // of 125GB; leaves ~13GB for OS + page cache
}
