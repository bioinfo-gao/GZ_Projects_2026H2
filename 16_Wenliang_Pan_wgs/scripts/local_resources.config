// Project 16 — Wenliang Pan human germline WGS (2 samples)
// Context: runs SOLO on the server (no co-running pipeline as of 2026-07-15).
// Proven-stable proj4 design: queueSize=2, generous per-task RAM, bwa-mem2 aligner.
// Thread budget: 2 samples x 16 cpus = 32 threads sustained  (<= 56 cap). OK.
// RAM: worst case 2x BWAMEM2 @ 60GB = 120GB simultaneously (total 125GB) -> keep
//      --max_memory 120.GB on the CLI so Nextflow never over-commits.

process {
    cpus   = 16
    memory = 50.GB

    withName: 'BWAMEM2_MEM' {
        cpus   = 16
        memory = 60.GB
    }

    // Defensive: CNNScoreVariants is a hidden CPU hog (~8.7 cores/task, low RSS,
    // memory-throttling does NOT limit it). queueSize=2 already caps concurrency,
    // but pin cpus so it never grabs more slots than intended. (proj14 load-152 lesson)
    withName: '.*CNNSCOREVARIANTS.*' {
        cpus = 9
    }
}

executor {
    name      = 'local'
    queueSize = 2      // only 2 samples in flight -> both run concurrently, machine stays calm
}
