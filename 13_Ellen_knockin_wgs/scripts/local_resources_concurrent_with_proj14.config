// nf-core/sarek 资源配置 —— 13_Ellen_knockin_wgs
// ⚠️ 本文件专用于"与项目14并跑"的场景，资源刻意降配，不是标准/独立跑的配置。
//
// 背景（2026-07-09）：项目14 Study A 的比对阶段(BWAMEM2_MEM，最吃线程的部分)已跑完，
// 目前处于去重(MarkDuplicates,单线程为主)+TIDDIT 的收尾阶段，实测负载很低
// （load average ~5、内存仅用17GB/125GB），但它自己的 executor 仍声明了 48 线程上限，
// 且后续 Mutect2 阶段用量未知——两个 nextflow 实例是各自独立调度，互不知道对方在跑，
// 所以必须由人工把 CLAUDE.md 的"全服务器 ≤28物理核/≤56线程"预算，在两个项目间显式切分，
// 不能各自按满配跑。
//
// 分配：本项目(并跑期间) 上限 24 线程 / 80GB；留 32 线程 / 45GB+ 给项目14 的收尾及可能的
// Mutect2 峰值。两者峰值理论叠加 ≤56 线程，在实测项目14当前负载(个位数核)下有充足余量。
//
// ⚠️ 等项目14完全跑完（Study A + Study B 都结束）后，应改回同目录下的
// `local_resources.config`（独立满配：48线程/108GB，queueSize=2，BWAMEM2_MEM 16cpu/50GB）
// 重新跑或继续跑，以恢复正常速度——不要在项目14结束后仍长期用这份降配配置。
executor {
    name      = 'local'
    cpus      = 24
    memory    = '80 GB'
    queueSize = 2
}

process {
    withLabel: 'process_low'         { cpus = 1;  memory = '4 GB'  }
    withLabel: 'process_medium'      { cpus = 3;  memory = '10 GB' }
    withLabel: 'process_high'        { cpus = 8;  memory = '24 GB'; time = '96h' }
    withLabel: 'process_high_memory' { memory = '28 GB' }

    // 2 个样并行：2×12=24 线程（=executor上限）；内存按 proj14 实测 bwa-mem2 单进程
    // ~18GB 的经验值定（16cpu时~18GB，12cpu时相近或略高），留安全余量到 24GB。
    withName: '.*BWAMEM2_MEM.*'      { cpus = 12; memory = '24 GB' }
    withName: '.*BWAMEM2_INDEX.*'    { cpus = 8;  memory = '40 GB' }   // 建索引单次运行，不与比对并发
    withName: '.*MARKDUPLICATES.*'   { cpus = 4;  memory = '20 GB' }
    withName: '.*TIDDIT.*'           { cpus = 4;  memory = '12 GB' }
    withName: '.*MOSDEPTH.*'         { cpus = 3;  memory = '10 GB' }
}
