// nf-core/sarek 本机资源上限 —— 13_Ellen_knockin_wgs
// 服务器：64 逻辑核 / 125 GB RAM。CLAUDE.md 硬上限：≤28 物理核 / ≤56 线程。
// 分配：executor 48 线程 + 108 GB，预留系统/交互。
// 真实 WGS 样本比对(bwa-mem2)吃内存，故 queueSize=2：同时只跑 2 个样本，防内存紧张。
executor {
    name      = 'local'
    cpus      = 48
    memory    = '108 GB'
    queueSize = 2
}

process {
    // 标签级默认
    withLabel: 'process_low'         { cpus = 2;  memory = '6 GB'  }
    withLabel: 'process_medium'      { cpus = 6;  memory = '16 GB' }
    withLabel: 'process_high'        { cpus = 16; memory = '40 GB'; time = '72h' }
    withLabel: 'process_high_memory' { memory = '50 GB' }

    // 关键进程精调（2 个样并行：2×16=32 线程、2×50=100 GB，均在上限内）
    withName: '.*BWAMEM2_MEM.*'      { cpus = 16; memory = '50 GB' }
    withName: '.*BWAMEM2_INDEX.*'    { cpus = 8;  memory = '60 GB' }   // 合并参考建索引，单次
    withName: '.*MARKDUPLICATES.*'   { cpus = 8;  memory = '40 GB' }
    withName: '.*MANTA.*'            { cpus = 12; memory = '30 GB' }
    withName: '.*TIDDIT.*'           { cpus = 8;  memory = '20 GB' }
    withName: '.*MOSDEPTH.*'         { cpus = 6;  memory = '16 GB' }
}
