// 限制 local 执行器的资源上限，防止压垮服务器
// 服务器总资源：64 CPUs + 125 GB 内存（实测 free -h）
// 此处分配：48 CPUs + 96 GB 内存，预留给系统及其他任务
executor {
    name = 'local'
    cpus   = 48
    memory = '96 GB'
}

process {
    withLabel: 'process_low' {
        cpus   = 2
        memory = '4 GB'
    }
    withLabel: 'process_medium' {
        cpus   = 6
        memory = '12 GB'
    }
    withLabel: 'process_high' {
        cpus   = 12
        memory = '24 GB'
        time   = '48h'
    }
    withLabel: 'process_high_memory' {
        memory = '48 GB'
    }
}
