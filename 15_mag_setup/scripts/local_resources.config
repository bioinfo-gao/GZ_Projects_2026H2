/*
 * Local resource + container config for nf-core/mag 5.4.2 on this server.
 * Keeps total concurrent usage within the 28-core / 56-thread house limit.
 *
 * mag 5.4.2 uses the MODERN nf-core template: resource ceilings come from
 * process.resourceLimits (NOT the old check_max/--max_cpus/--max_memory, which
 * no longer exist). Requires Nextflow >= 25.04.2 (mag_biobakery has 26.04.4).
 */

singularity {
    enabled     = true
    autoMounts  = true
    cacheDir    = '/Work_bio/gao/configs/.singularity'
    pullTimeout = '30m'
}

process {
    resourceLimits = [ cpus: 24, memory: 96.GB, time: 48.h ]
}
