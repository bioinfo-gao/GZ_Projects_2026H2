/*
 * Local resource + container config for nf-core/mag on this server.
 * Keeps total concurrent usage within the 28-core / 56-thread house limit.
 *
 * NOTE (mag 2.5.1 specific): this pipeline still uses the OLD nf-core template
 * with check_max() + --max_cpus/--max_memory/--max_time. Those params ARE honoured
 * (unlike taxprofiler 2.0.1, which ignores them and needs process.resourceLimits).
 * We ALSO set resourceLimits here as a belt-and-braces cap in case of template drift.
 */

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = '/Work_bio/gao/configs/.singularity'
    // Give each container a private, writable /tmp overlay. Without this, concurrent
    // CENTRIFUGE tasks collide on host /tmp: centrifuge names its decompression FIFO
    // /tmp/<in-container-PID>.inpipe1, PIDs repeat across containers, and the second
    // task dies with "mkfifo(/tmp/NN.inpipe1) failed" -> exit 17. (verified on test profile)
    runOptions = '--writable-tmpfs'
}

// Total concurrency cap for the local executor (per-task caps come from --max_cpus/--max_memory).
executor {
    cpus   = 24
    memory = '96.GB'
}

process {
    resourceLimits = [ cpus: 24, memory: 96.GB, time: 48.h ]
}
