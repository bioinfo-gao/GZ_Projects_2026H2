// Local resource caps for nf-core/taxprofiler runs on this server.
// Server has 32 physical cores / 64 threads and 125 GB RAM.
// Hard limit per working-environment policy: max 28 physical cores / 56 threads,
// and always leave headroom for OS / SSH / interactive use.
// These caps are passed as nf-core standard --max_* params (see run scripts),
// this file only caps how many cores the local executor will hand out concurrently.

executor {
    cpus   = 24
    memory = '96.GB'
}

process {
    resourceLimits = [
        cpus: 24,
        memory: 96.GB,
        time: 12.h
    ]
}

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = '/Work_bio/gao/configs/.singularity'
}
